# ============================================
# EXCLUDE FROM GIT (Large files & generated)
# ============================================

# Large dataset files
*.zip
*.tar.gz
*.rar
*.7z
ddidiversedermatologyimages.zip

# Dataset images (regenerated from source)
DDI/images/
DDI/images/*.png
DDI/images/*.jpg
DDI/images/*.jpeg

# Processed/generated data
data/raw/*
data/processed/*
data/interim/*
data/*.csv
data/*.parquet

# All CSV files (datasets)
*.csv

# Python cache & bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environments
env/
venv/
.venv/
ENV/
.Python

# Jupyter checkpoints & outputs
.ipynb_checkpoints/
*.ipynb_checkpoints/

# IDE & editors
.vscode/
.idea/
*.code-workspace
*.swp
*~

# Model files (large trained models)
models/*.pt
models/*.pth
models/*.h5
models/*.pkl
models/*.weights
models/*.ckpt

# Generated reports & figures
reports/figures/**/*.png
reports/figures/**/*.pdf
reports/figures/**/*.jpg
reports/*.csv

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# Logs
*.log
logs/

# Streamlit cache
.streamlit/

# Temporary files
*.tmp
*.temp
*.bak


# ============================================
# INCLUDE IN GIT (Source code & config)
# ============================================

# Keep directory structure (optional)
!data/.gitkeep
!reports/.gitkeep
!reports/figures/.gitkeep

# Include config files
!config/*.yml
!config/*.yaml

# Include source code
!src/**/*.py
!dashboard/**/*.py
!notebooks/*.ipynb

# Include documentation
!README.md
!reports/*.md
!*.md

# Include requirements
!requirements.txt
